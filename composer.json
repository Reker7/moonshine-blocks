{
    "name": "reker7/moonshine-blocks",
    "description": "Dynamic content blocks management for MoonShine admin panel",
    "keywords": [
        "moonshine",
        "blocks",
        "cms",
        "admin"
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1|^8.2|^8.4",
        "ext-json": "*",
        "moonshine/moonshine": "^4.0",
        "reker7/moonshine-blocks-core": "^1.0",
        "reker7/moonshine-fields-builder": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0",
        "rector/rector": "^1.2.10"
    },
    "autoload": {
        "psr-4": {
            "Reker7\\MoonShineBlocks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Reker7\\MoonShineBlocks\\Tests\\": "tests/",
            "Reker7\\MoonShineBlocks\\Database\\Factories\\": "database/factories/"
        }
    },
    "conflict": {
        "moonshine/moonshine": "<4.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "rector": "vendor/bin/rector process --clear-cache",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Reker7\\MoonShineBlocks\\Providers\\MoonShineBlocksServiceProvider"
            ]
        }
    }
}
